# ============================================================
# Crossfire Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# ---- Fireworks AI ----
# Get from: https://fireworks.ai/account/api-keys
# Hackathon provides $50 in credits per participant.
FIREWORKS_API_KEY=

# ---- Fireworks Model ----
# Gemma 27B for complex semantic translations
FIREWORKS_MODEL=accounts/fireworks/models/gemma2-27b-it

# ---- vLLM (Local Model Server) ----
# URL of the vLLM server (started by docker-compose)
VLLM_URL=http://localhost:8001

# Local model — Gemma 4 12B (unsloth/gemma-4-12b-it, served via vLLM on MI300X)
VLLM_MODEL=unsloth/gemma-4-12b-it
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.2

# ---- AMD Cloud / ROCm ----
# Set to true when running on AMD Developer Cloud with MI300X
AMD_GPU_ENABLED=true
# Target architecture (gfx942 = MI300X)
PYTORCH_ROCM_ARCH=gfx942
# MI300X is gfx942 — no override needed. Leave empty for production.
# HSA_OVERRIDE_GFX_VERSION is only for older MI100/MI200 shims.
HSA_OVERRIDE_GFX_VERSION=

# ---- RAG ----
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RAG_TOP_K=5

# ---- Sandbox ----
# Docker container name for ROCm sandbox (dev mode only)
SANDBOX_CONTAINER=crossfire-sandbox
# Max seconds for compile + run
SANDBOX_TIMEOUT=60
# Max memory per job (GB)
SANDBOX_MEMORY_GB=8

# ---- Agent ----
AGENT_MAX_ITERATIONS=5
AGENT_ROUTING_THRESHOLD=0.4
AGENT_DIFF_THRESHOLD=1e-5

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Stub Mode (Development) ----
# CRITICAL: Both default to false. A regex swap is NOT a translation.
# Enable ONLY for local dev when no GPU/vLLM is available.
ALLOW_STUB_FALLBACK=false
ALLOW_STUB_SANDBOX=false

# ---- Optional: HuggingFace ----
# Only needed for fine-tuning script or downloading gated models
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Optional: Basic Auth for Demo ----
# Protects demo from burning API credits during judging
# DEMO_BASIC_AUTH_USER=crossfire
# DEMO_BASIC_AUTH_PASS=amdhackathon2026
